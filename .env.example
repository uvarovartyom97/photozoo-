# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_WORKSHEET_NAME=*
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# Multiple trading points
# Leave this empty to use the single-table settings above.
TRADING_POINTS_FILE=
# TRADING_POINTS_JSON can be used instead of TRADING_POINTS_FILE.
TRADING_POINTS_JSON=

# Telegram
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_CHAT_ID=-1001234567890

# Report
TRADING_POINT_NAME=Default
REPORT_TITLE=Ракета Челябинск
REPORT_TIMEZONE=Asia/Yekaterinburg
REPORT_SEND_TIME=22:00
REPORT_STATE_FILE=.photozoom-report-state.json
DATE_COLUMN=date
REVENUE_COLUMN=revenue
COST_COLUMN=cost
ORDERS_COLUMN=orders
CONVERSIONS_COLUMN=conversions
VISITS_COLUMN=visits
REPORT_DATE=
FORCE_SEND=false
DRY_RUN=false
